{
  "agents": {
    "logger-agent": {
      "module_path": ".cursor/agents/logger_agent.py",
      "class": "LoggerAgent",
      "description": "Merge host change logs into ~/infra/CHANGE.log with append-only semantics.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["logging", "audit", "observability"],
      "outputs": ["CHANGE.log"],
      "source_logs": ["server-changelog.md", "**/*.log"],
      "state_file": ".state/logger-agent.json",
      "target_log": "CHANGE.log"
    },
    "lint-resolver-agent": {
      "module_path": ".cursor/agents/lint_resolver_agent.py",
      "class": "LintResolverAgent",
      "description": "Resolve lint warnings with language aware fixers.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["quality", "lint"],
      "outputs": ["server-changelog.md"],
      "resolvers": [
        {
          "id": "python-ruff",
          "patterns": [
            "*.py",
            "scripts/**/*.py",
            ".cursor/**/*.py"
          ],
          "diagnostics": [
            [
              ["uv", "run", "ruff", "check", "--exit-zero", "--format", "json"],
              ["ruff", "check", "--exit-zero", "--format", "json"]
            ]
          ],
          "commands": [
            [
              ["uv", "run", "ruff", "check", "--fix", "{file}"],
              ["ruff", "check", "--fix", "{file}"]
            ],
            [
              ["uv", "run", "ruff", "format", "{file}"],
              ["ruff", "format", "{file}"]
            ]
          ],
          "verify": [
            [
              ["uv", "run", "ruff", "check", "{file}"],
              ["ruff", "check", "{file}"]
            ]
          ]
        }
      ]
    },
    "preflight-agent": {
      "module_path": ".cursor/agents/preflight_agent.py",
      "class": "PreflightAgent",
      "description": "Run scripts/preflight.sh under Infisical.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["preflight", "infra-architect"],
      "outputs": ["server-changelog.md"],
      "default_env": "production"
    },
    "deploy-agent": {
      "module_path": ".cursor/agents/deploy_agent.py",
      "class": "DeployAgent",
      "description": "Execute scripts/deploy.ah <target> under Infisical.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["deployment", "dev-orchestrator"],
      "outputs": ["server-changelog.md"],
      "default_env": "production"
    },
    "status-agent": {
      "module_path": ".cursor/agents/status_agent.py",
      "class": "StatusAgent",
      "description": "Run scripts/status.sh and scripts/health-check.sh.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["verification", "dev-orchestrator"],
      "outputs": ["server-changelog.md"]
    },
    "discovery-cartographer": {
      "module_path": ".cursor/agents/discovery_cartographer_agent.py",
      "class": "DiscoveryCartographerAgent",
      "description": "Scan repo/services/env templates for drift and inventory updates.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["inventory", "planning"],
      "outputs": ["PROJECT_PLAN.md", "server-changelog.md"],
      "project_plan": "PROJECT_PLAN.md"
    },
    "compose-engineer": {
      "module_path": ".cursor/agents/compose_engineer_agent.py",
      "class": "ComposeEngineerAgent",
      "description": "Run docker compose config via Infisical and verify Traefik/health requirements.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["compose", "traefik", "lint"],
      "outputs": ["server-changelog.md"],
      "default_env": "production"
    },
    "secrets-steward": {
      "module_path": ".cursor/agents/secrets_steward_agent.py",
      "class": "SecretsStewardAgent",
      "description": "Audit ${VAR} usage and ensure Infisical/env template coverage.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["security", "secrets"],
      "outputs": ["server-changelog.md"],
      "default_env": "production",
      "infisical_path": "prod/"
    },
    "deployment-runner": {
      "module_path": ".cursor/agents/deployment_runner_agent.py",
      "class": "DeploymentRunnerAgent",
      "description": "Execute preflight/deploy/status/health scripts with edge-network enforcement.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["deployment", "runner"],
      "outputs": ["server-changelog.md"],
      "default_env": "production"
    },
    "security-sentinel": {
      "module_path": ".cursor/agents/security_sentinel_agent.py",
      "class": "SecuritySentinelAgent",
      "description": "Run ClamAV scan and verify Zero-Trust posture.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["security", "clamav"],
      "outputs": ["server-changelog.md"]
    },
    "api-gatekeeper": {
      "module_path": ".cursor/agents/api_gatekeeper_agent.py",
      "class": "APIGatekeeperAgent",
      "description": "Validate Kong config, domain templates, and reload Kong.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["kong", "cloudflare", "ingress"],
      "outputs": ["server-changelog.md"],
      "default_env": "production"
    },
    "documentation-scribe": {
      "module_path": ".cursor/agents/documentation_scribe_agent.py",
      "class": "DocumentationScribeAgent",
      "description": "Append automation notes to README/PROJECT_PLAN/infra-build-plan and changelogs.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["documentation", "audit"],
      "outputs": ["README.md", "PROJECT_PLAN.md", "infra-build-plan.md", "CHANGE.log", "server-changelog.md"]
    },
    "review-agent": {
      "module_path": ".cursor/agents/review_agent.py",
      "class": "ReviewAgent",
      "description": "Final verification gate ensuring diffs, compose configs, and validation evidence are present.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["review", "quality"],
      "outputs": ["CHANGE.log", "server-changelog.md"]
    },
    "release-agent": {
      "module_path": ".cursor/agents/release_agent.py",
      "class": "ReleaseAgent",
      "description": "Create signed commits with assumption annotations and optional push.",
      "allowed_hosts": ["mac", "vps"],
      "tags": ["release", "git"],
      "outputs": ["server-changelog.md"]
    },
    "automator": {
      "module_path": ".cursor/agents/automator_agent.py",
      "class": "AutomatorAgent",
      "description": "Trigger n8n workflows under Infisical and emit webhook events.",
      "allowed_hosts": ["mac", "vps", "linux"],
      "tags": ["automation", "n8n"],
      "outputs": ["server-changelog.md"],
      "default_env": "production",
      "workflows": [
        "daily-maintenance",
        "post-recovery-audit"
      ]
    }
  }
}
